      <aliases enabled='yes' />
      <column caption='YTD Total Sales' datatype='integer' default-format='n&quot;$&quot;#,##0,,.00M;-&quot;$&quot;#,##0,,.00M' name='[Calculation_1526999832674304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Date]) = {MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Price ($)]&#13;&#10;END)' />
      </column>
      <column caption='YoY Sales Growth' datatype='real' default-format='p0.00%' name='[Calculation_1526999840821250]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1526999832674304]-[YTD Total Sales (copy)_1526999840436225])&#13;&#10;/ [YTD Total Sales (copy)_1526999840436225]' />
      </column>
      <column caption='YTD Cars Sold' datatype='integer' default-format='c&quot;#&quot;#,##0,.00K' name='[Calculation_1526999999115267]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;YEAR([Date])={MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
      </column>
      <column caption='YoY Cars Sold Growth' datatype='real' default-format='p0.00%' name='[Calculation_1527000000102405]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1526999999115267]-[YTD Cars Sold (copy)_1526999999721476])/[YTD Cars Sold (copy)_1526999999721476]' />
      </column>
      <column caption='YTD Avg Price' datatype='real' default-format='c&quot;$&quot;#,##0,.00K' name='[Calculation_1527000002252809]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1526999832674304]/[Calculation_1526999999115267]' />
      </column>
      <column caption='PYTD Avg Price' datatype='real' name='[Calculation_1527000002433034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[YTD Total Sales (copy)_1526999840436225]/[YTD Cars Sold (copy)_1526999999721476]' />
      </column>
      <column caption='YoY Avg Growth' datatype='real' name='[Calculation_1527000002629643]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1527000002252809]-[Calculation_1527000002433034])/[Calculation_1527000002433034]' />
      </column>
      <column caption='Min Date' datatype='date' name='[Calculation_1527000554147856]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{MIN([Date])}' />
      </column>
      <column caption='Max Date' datatype='date' name='[Calculation_1527000554401809]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{MAX([Date])}' />
      </column>
      <column caption='Car id' datatype='string' name='[Car_id]' role='dimension' type='nominal' />
      <column datatype='string' name='[Color]' role='dimension' type='nominal' />
      <column caption='Dealer Name' datatype='string' name='[Dealer_Name]' role='dimension' type='nominal' />
      <column caption='Dealer No' datatype='string' name='[Dealer_No]' role='dimension' type='nominal' />
      <column caption='Dealer Region' datatype='string' name='[Dealer_Region]' role='dimension' type='nominal' />
      <column datatype='string' name='[Transmission]' role='dimension' type='nominal' />
      <column caption='PYTD Cars Sold ' datatype='integer' name='[YTD Cars Sold (copy)_1526999999721476]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;YEAR([Date])={MAX(YEAR([Date]))}-1&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
      </column>
      <column caption='PYTD Total Sales ' datatype='integer' name='[YTD Total Sales (copy)_1526999840436225]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Date]) = {MAX(YEAR([Date]))} - 1&#13;&#10;THEN&#13;&#10;[Price ($)]&#13;&#10;END)' />
      </column>
